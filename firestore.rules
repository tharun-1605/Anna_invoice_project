rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isString(field) {
      return field is string;
    }

    function isNumber(field) {
      return field is int || field is float;
    }

    function isTimestamp(field) {
      return field is timestamp;
    }

    function hasOnly(data, fields) {
      return data.keys().hasOnly(fields);
    }

    function isCompany(data) {
      return hasOnly(data, ['name', 'address', 'phone', 'email', 'updatedAt', 'signatureBase64'])
        && isString(data.name)
        && isString(data.address)
        && isString(data.phone)
        && isString(data.email)
        && isTimestamp(data.updatedAt)
        && (data.signatureBase64 is string || !data.keys().hasAny(['signatureBase64']));
    }

    function isPackage(data) {
      return (hasOnly(data, ['name', 'description', 'price', 'items', 'updatedAt']) || hasOnly(data, ['name', 'description', 'price', 'items', 'deliverables', 'updatedAt']))
        && isString(data.name)
        && isString(data.description)
        && isNumber(data.price)
        && data.items is list
        && (data.deliverables is list || !data.keys().hasAny(['deliverables']))
        && isTimestamp(data.updatedAt);
    }

    function isClient(data) {
      return hasOnly(data, ['name', 'phone', 'email', 'address', 'updatedAt', 'fromLead', 'eventDate', 'priority', 'reference', 'isRejected', 'rejectReason'])
        && isString(data.name)
        && isString(data.phone)
        && isString(data.email)
        && isString(data.address)
        && isTimestamp(data.updatedAt)
        && (data.fromLead is bool || !data.keys().hasAny(['fromLead']))
        && (data.eventDate is string || !data.keys().hasAny(['eventDate']))
        && (data.priority is string || !data.keys().hasAny(['priority']))
        && (data.reference is string || !data.keys().hasAny(['reference']))
        && (data.isRejected is bool || !data.keys().hasAny(['isRejected']))
        && (data.rejectReason is string || !data.keys().hasAny(['rejectReason']));
    }

    function isLead(data) {
      return hasOnly(data, ['name', 'phone', 'email', 'address', 'updatedAt', 'eventDate', 'priority', 'reference', 'isRejected', 'rejectReason'])
        && isString(data.name)
        && isString(data.phone)
        && isString(data.email)
        && isString(data.address)
        && isTimestamp(data.updatedAt)
        && (data.eventDate is string || !data.keys().hasAny(['eventDate']))
        && (data.priority is string || !data.keys().hasAny(['priority']))
        && (data.reference is string || !data.keys().hasAny(['reference']))
        && (data.isRejected is bool || !data.keys().hasAny(['isRejected']))
        && (data.rejectReason is string || !data.keys().hasAny(['rejectReason']));
    }

    function isStudioItem(data) {
      return hasOnly(data, ['name', 'price', 'updatedAt'])
        && isString(data.name)
        && isNumber(data.price)
        && isTimestamp(data.updatedAt);
    }

    function isInvoice(data) {
      return hasOnly(data, [
          'number',
          'company',
          'client',
          'date',
          'dueDate',
          'items',
          'subtotal',
          'total',
          'paid',
          'amountDue',
          'notes',
          'createdAt',
          'type',
          'discountAmount',
          'payments',
          'isReminderDismissed',
          'shootDate',
          'shootVenue',
          'shootType'
        ])
        && isString(data.number)
        && isString(data.notes)
        && (data.isReminderDismissed is bool || !data.keys().hasAny(['isReminderDismissed']))
        && data.company is map
        && data.client is map
        && hasOnly(data.company, ['id', 'name', 'address', 'phone', 'email', 'signatureBase64'])
        && hasOnly(data.client, ['id', 'name', 'phone', 'email', 'address'])
        && isString(data.company.id)
        && isString(data.company.name)
        && isString(data.company.address)
        && isString(data.company.phone)
        && isString(data.company.email)
        && (data.company.signatureBase64 is string || !data.company.keys().hasAny(['signatureBase64']))
        && isString(data.client.id)
        && isString(data.client.name)
        && isString(data.client.phone)
        && isString(data.client.email)
        && isString(data.client.address)
        && isTimestamp(data.date)
        && isTimestamp(data.dueDate)
        && isTimestamp(data.createdAt)
        && data.items is list
        && data.items.size() > 0
        && data.items.size() <= 100
        && isNumber(data.subtotal)
        && isNumber(data.total)
        && isNumber(data.paid)
        && isNumber(data.amountDue)
        && isNumber(data.discountAmount)
        && isString(data.type)
        && data.payments is list
        && (data.shootDate is timestamp || data.shootDate == null || !data.keys().hasAny(['shootDate']))
        && (data.shootVenue is string || data.shootVenue == null || !data.keys().hasAny(['shootVenue']))
        && (data.shootType is string || data.shootType == null || !data.keys().hasAny(['shootType']));
    }

    match /companies/{companyId} {
      allow read, delete: if true;
      allow create, update: if isCompany(request.resource.data);
    }

    match /clients/{clientId} {
      allow read, delete: if true;
      allow create, update: if isClient(request.resource.data);
    }

    match /packages/{packageId} {
      allow read, delete: if true;
      allow create, update: if isPackage(request.resource.data);
    }

    match /leads/{leadId} {
      allow read, delete: if true;
      allow create, update: if isLead(request.resource.data);
    }

    match /studio_items/{itemId} {
      allow read, delete: if true;
      allow create, update: if isStudioItem(request.resource.data);
    }

    match /invoices/{invoiceId} {
      allow read, delete: if true;
      allow create, update: if isInvoice(request.resource.data);
    }
  }
}
